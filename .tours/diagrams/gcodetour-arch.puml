@startuml
' C4 Container view of gCodeTour's playback architecture. Each addressable
' element carries a ct://el/<alias> sentinel via $link.
' Render: skills/gcodetour-author/scripts/render-diagrams.sh
' Apply the C4 theme AFTER the include — the include resets element styling, so a
' theme placed before it renders outlined/white instead of solid.
' C4_blue_new (solid blue) pairs with the bluegray activity default.
!include <C4/C4_Container>
!theme C4_blue_new from <C4/themes>
skinparam defaultFontName Roboto

LAYOUT_WITH_LEGEND()

title gCodeTour — playback architecture

Person(dev, "Developer", "Takes a guided tour", $link="ct://el/dev")
System_Boundary(ext, "gCodeTour extension") {
  Container(provider, "Tour Provider", "TypeScript", "Discovers and watches .tour files", $link="ct://el/provider")
  Container(store, "MobX Store", "TypeScript", "Holds the active tour and step", $link="ct://el/store")
  Container(player, "Player", "TypeScript", "Renders each step as a comment thread", $link="ct://el/player")
  Container(diagram, "Diagram Panel", "TypeScript + webview", "Shows synchronized diagrams", $link="ct://el/diagram")
}
ContainerDb(files, ".tour files", "JSON", "Stored under .tours/", $link="ct://el/files")

Rel(dev, player, "Navigates steps")
Rel(provider, files, "Reads")
Rel(provider, store, "Populates")
Rel(store, player, "Drives (MobX reaction)")
Rel(store, diagram, "Drives (onDidStartTour)")

@enduml
